<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_sale_stock_reserve_release_form" model="ir.ui.view">
        <field name="name">sale.stock.reserve.release.form</field>
        <field name="model">sale.stock.reserve.release</field>
        <field name="arch" type="xml">
            <form string="Cancel All Reservations">
                <p class="oe_grey">
                    The following stock reservations will be cancelled.
                    Are you sure you want to proceed?
                </p>
                <field name="sale_order_id" invisible="1" />
                <field name="reservation_ids" nolabel="1">
                    <tree create="0" delete="0" edit="0">
                        <field name="product_id" />
                        <field name="product_uom_qty" string="Quantity" />
                        <field name="product_uom" string="UoM" />
                        <field name="location_id" />
                        <field name="location_dest_id" />
                        <field name="date_validity" />
                        <field name="state" />
                    </tree>
                </field>
                <footer>
                    <button
                    string="Confirm Cancellation"
                    name="button_release"
                    type="object"
                    class="btn-primary"
                />
                    or
                    <button special="cancel" class="oe_link" string="Discard" />
                </footer>
            </form>
        </field>
    </record>
    <record id="action_sale_stock_reserve_release" model="ir.actions.act_window">
        <field name="name">Cancel All Reservations</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.stock.reserve.release</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
