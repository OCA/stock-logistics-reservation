<odoo>
    <record id="view_stock_reserve_rule_form" model="ir.ui.view">
        <field name="name">stock.reserve.rule.form</field>
        <field name="model">stock.reserve.rule</field>
        <field
            name="inherit_id"
            ref="stock_reserve_rule.view_stock_reserve_rule_form"
        />
        <field name="arch" type="xml">
            <field name="removal_strategy" position="after">
                <field
                    name="full_demand_fallback_location_ids"
                    invisible="removal_strategy != 'full_demand'"
                />
            </field>
            <xpath
                expr="//field[@name='rule_removal_ids']/form//field[@name='removal_strategy']"
                position="after"
            >
                <field
                    name="full_demand_fallback_location_ids"
                    invisible="removal_strategy != 'full_demand'"
                />
            </xpath>
        </field>
    </record>
</odoo>
